rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /meta/currentSession {
      allow read: if true;
      allow write: if false;
    }

    match /sessions/{sessionId}/participants/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /sessions/{sessionId}/groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.creatorId == request.auth.uid
        && request.resource.data.creatorId == resource.data.creatorId
        && request.resource.data.menu == resource.data.menu
        && request.resource.data.name == resource.data.name
        && request.resource.data.linkUrl == resource.data.linkUrl
        && request.resource.data.imageUrl == resource.data.imageUrl
        && request.resource.data.status == resource.data.status
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    match /sessions/{sessionId}/memberships/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.participantId == request.auth.uid;
      allow delete: if isSignedIn()
        && (
          request.auth.uid == uid
          || (
            exists(/databases/$(database)/documents/sessions/$(sessionId)/groups/$(resource.data.groupId))
            && get(/databases/$(database)/documents/sessions/$(sessionId)/groups/$(resource.data.groupId)).data.creatorId == request.auth.uid
          )
        );
    }
  }
}
